# execute command: return True is everything OK, False otherwise
def execute_command(command,logfile):
  try:
    subprocess.check_call(command.split(),stdout=logfile,stderr=logfile)
  except subprocess.CalledProcessError:
    print("Error executing command line:")
    print("\t"+ command)
    print("Check log file: " + logfile.name)
    return False
  return True

# execute command and return CompletedProcess 
def local_execute(command):
    return subprocess.run(command.split(),encoding="utf-8",
                          stdout=subprocess.PIPE,stderr=subprocess.PIPE)

def execute_commands(commands,logfile,p):
  # execute in parallel 
  print("---- Executing", p, "parallel processes")
  with Pool(p) as pool:
    completed = pool.map(local_execute,commands)
  print("---- Parallel processing completed")
  done  = True
  for c,r in zip(commands,completed):
    print("Command:", c, file=logfile)
    print("Return code:", r.returncode, file=logfile) 
    print("---stdout---\n",r.stdout,"\n--stderr--\n",r.stderr, file=logfile) 
    if r.returncode!=0:
      print("Error executing command line:")
      print("\t"+ c)
      print("Check log file: " + logfile.name)
      done=False
  return done


# number of bits to represent integers from 0 up to n-1
def bits(n):
  assert n>0
  b = maxv = 1
  while(maxv<n-1):
    b +=1
    maxv = 1+2*maxv
  return b


# check if the files source.ext0 source.ext1 have to be generated 
def need_rebuild(source,*exts):
  assert os.path.exists(source), "Missing source: " + source
  for ext in exts:
    dest = source + ext
    if not os.path.exists(dest):
      return True           #one destination missing: we need to build it
    # rebuild if dest is older   
    if os.path.getmtime(dest) < os.path.getmtime(source):
      return True
  # all dependencies exists and are more recent than the source 
  return False 

def need_rebuild_multipart(source,num,*exts):
  assert os.path.exists(source), "Missing source: " + source
  for ext in exts:
    for i in range(num):
      newext = filext_multipart(num,i) + ext
      if need_rebuild(source,newext):
        return True
  # all dependencies exists and are more recent than the source 
  return False 

# return the extension for multipart file
def filext_multipart(n,i):
  assert i<n, "Illegal parameters"
  if n==1:
    return ""
  return ".{tot}.{part}".format(tot=n,part=i)


