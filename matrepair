# execute command: return True is everything OK, False otherwise
def execute_command(command,logfile,outfile=None):
  try:
    #subprocess.run(command.split(),stdout=logfile,stderr=logfile,check=True,env=env)
    if not outfile:
      outfile = logfile
    subprocess.check_call(command.split(),stdout=logfile,stderr=logfile)
  except subprocess.CalledProcessError:
    print("Error executing command line:")
    print("\t"+ command)
    print("Check log file: " + logfile.name)
    return False
  return True

# number of bits to represent integers fro 0 up to n-1
def bits(n):
  assert n>0
  b = maxv = 1
  while(maxv<n-1):
    b +=1
    maxv = 1+2*maxv
  return b

# estimate space usage of RePair output using the minimum number of bits 
# for symbol, no other complex econding include also the .val file
# *** No longer used: we don't need the estimate since we implemeted the actual compression    
def estimate_compressed_grammar_size(basename,isize):
  rsize = os.path.getsize(basename+".vc.R")
  assert (rsize-4)%8 == 0, "Invalid .R file format" 
  nnonterm = (rsize-4)//8   # number of non terminals 
  with open(basename + ".vc.R","rb") as f:
    s = f.read(4)
    nterm = struct.unpack('I',s)[0] # read # of terminals in first 32 bit uint
  totbits = bits(nterm+nnonterm)
  print(" >> Terminals:",nterm,"Non-terms:", nnonterm, "Total:", nterm+nnonterm, \
        "Bits x symbol:", totbits)
  numc = os.path.getsize(basename+".vc.C")//4   # symbols in C string 
  tot = ((numc+2*nnonterm)*totbits+7)// 8       # bytes to represent C+R
  tot += 4 + os.path.getsize(basename+".val")   # 1 extra byte in R and val file 
  print(" >> Compressed grammar+val representation size:",tot, "bytes  ({0:.2f}%)".format(100*tot/isize))

# check if the files source.ext... has to be computed 
def need_rebuild(source,*exts):
  assert os.path.exists(source), "Missing source: " + source
  for ext in exts:
    dest = source + ext
    if not os.path.exists(dest):
      return True           #one destination missing: we need to build it
    # rebuild if dest is older   
    if os.path.getmtime(dest) < os.path.getmtime(source):
      return True
  # all dependencies exists and are more recent than the source 
  return False 


