#!/usr/bin/env python3

import sys, time, argparse, subprocess, os.path, struct, datetime
from psutil import virtual_memory

Description = """
Compressed Sparse Row-Value representation + Repair compression

  Compression:
     {exe} file [options]
  creates compressed files file.val file.vc.C and file.vc.R

  Decompression: (not yet implemented)
     {exe} -d file [options]
  decompresses file.val file.vc.C and file.vc.R to file.out          
"""

# path of the auxiliary tools
# irepair with memory constraint (symbols are integers) 
irepair_exe = "brepair/irepair0"
# idespair
idespair_exe = "brepair/idespair"
# tool to compute the value-column representation of a csv matrix
# note: if file names ends with .dbl then the matrix is assumed to be 
# in dense binary format (see mat2csrv.py help) 
mat2csrv_exe = "mat2csrv.py"
# tool to compress a sequence of int32 unsing ans-fold  
ansf_exe = "ans/encode.x"
# tool to compress a sequence of int32 unsing an integer vector from sdsl   
iv_exe = "sdsl/encode.x"


def main():
  show_command_line(sys.stderr)
  parser = argparse.ArgumentParser(description=Description.format(exe=sys.argv[0]), formatter_class=argparse.RawTextHelpFormatter)
  parser.add_argument('input', help='matrix csv file name', type=str)
  parser.add_argument('rows',  help='number of rows', type=int)
  parser.add_argument('cols', help='number of columns', type=int)
  parser.add_argument('-b', help='number of row blocks (def. 1)', type=int, default=1)
  parser.add_argument('-d', help='decompress',action='store_true')
  parser.add_argument('-c', help='decompress and check',action='store_true')
  parser.add_argument('-r', help='compression full report',action='store_true')
  parser.add_argument('-m', help='force repair to use at most M MBs (def. 95%% of available RAM)',default=-1, type=int)
  parser.add_argument('-y', help='lazy rebuild makefile style',action='store_true')
  # parser.add_argument('-k', help='keep intermediate files',action='store_true')
  parser.add_argument('-v', help="verbose", action='store_true')
  parser.add_argument('--noconv',  help='skip the CSRV conversion phase (debug only)',action='store_true')
  parser.add_argument('--norepair',  help='stop after the conversion phase (debug only)',action='store_true')
  args = parser.parse_args()
  # if no max RAM provided on command line uses 90% of total 
  if(args.m<0):
    mem = virtual_memory().total
    args.m = max(4000,int(0.90*mem/2**20)) # assume at least 4GB in case virtual_memory() misbehaves
  # init time counters 
  vc_time = repair_time = iv_time = ansf_time = 0


  logfile_name = args.input + ".log"
  # get absolute path to main matrepair directory 
  args.main_dir = os.path.dirname(os.path.abspath(__file__))
  print("Sending logging messages to file:", logfile_name)
  with open(logfile_name,"a",1) as logfile: # 1 for line buffering: keeps the logs ordered
    start0 = start = time.time()
    show_command_line(logfile)    
    if(args.d or args.c): # decompress and check
      print(" *** not implemented yet ***");
      return
      # to be fixed
      # exe = integer_despair_exe
      # command = "{exe} {file}".format(
                # exe = os.path.join(args.main_dir,exe), file=args.input)
      # print("==== Decompressing C+R files.\nCommand:", command)
      # if(execute_command(command,logfile)!=True):
        # return
      # print("Elapsed time: {0:.4f}".format(time.time()-start0));
      # if args.c:      
        # command = "cmp {file} {file}.out".format(file=args.input); 
        # print("==== Comparing decompressed file.\nCommand:", command);
        # if(execute_command(command,logfile)):
          # print("Decompressed file matches");
        # else:
          # print("Decompressed file differs");
                  
    else:       # mat2csrv + irepair
      # ----------conversion to the CSRV format 
      files_changed = need_rebuild_multipart(args.input, args.b, ".vc") or need_rebuild(args.input,".val")
      if args.noconv or (args.y and not files_changed):
        print("---- Skipping conversion dbl/csv->csrv")
      else:
        command = "{exe} {opts} {mfile} {rows} {cols}".format(
          exe = os.path.join(args.main_dir,mat2csrv_exe), mfile=args.input,
          rows = args.rows, cols=args.cols, opts = "-b %d" % args.b);
        print("==== Conversion dbl/csv->csrv\nCommand:", command)
        if(execute_command(command,logfile)!=True):
          return
        vc_time = time.time()-start
        print("Conversion time: {0:.4f}".format(vc_time))
        if args.norepair:
          print("==== Stopping after the conversion phase as requested")      
          return
          
      # now we have args.b different blocks 
      for bn in range(args.b):  
        basename = args.input + filext_multipart(args.b,bn)
        # ---- apply irepair to the .vc file 
        if args.y and not need_rebuild(basename+".vc", ".C", ".R"):
          print("---- Skipping irepair")
        else:
          start = time.time()
          command = "{exe} {mfile}.vc {mb}".format(mb=args.m,
                    exe = os.path.join(args.main_dir,irepair_exe), mfile=basename)
          print("==== Repair compression\nCommand:", command)
          if(execute_command(command,logfile)!=True):
           return
          repair_time += time.time()-start
          print("Repair time: {0:.4f}".format(repair_time))
          
        # ---- apply integer vector encoding to the .vc.C and vc.R files
        iv_time = 0 
        if args.y and not need_rebuild(basename+".vc.C", ".iv"):
          print("---- Skipping iv(C)")
        else:
          start = time.time()
          command = "{exe} {mfile}.vc.C ".format(
                    exe = os.path.join(args.main_dir,iv_exe), mfile=basename)
          print("==== Integer vector .C compression\nCommand:", command)
          if(execute_command(command,logfile)!=True):
           return
          iv_time += time.time()-start
        if args.y and not need_rebuild(basename+".vc.R", ".iv"):
          print("---- Skipping iv(R)")
        else:
          start = time.time()
          command = "{exe} {mfile}.vc.R ".format(
                    exe = os.path.join(args.main_dir,iv_exe), mfile=basename)
          print("==== Integer vector .R compression\nCommand:", command)
          if(execute_command(command,logfile)!=True):
           return
          iv_time += time.time()-start
          print("Integer vector compression time: {0:.4f}".format(iv_time))
        
        # ---- apply ans_fold-1 to the .vc.C file 
        if args.y and not need_rebuild(basename+".vc.C", ".ansf.1"):
          print("---- Skipping ans-fold")
        else:
          start = time.time()
          command = "{exe} {mfile}.vc.C ".format(
                    exe = os.path.join(args.main_dir,ansf_exe), mfile=basename)
          print("==== Ans-fold compression\nCommand:", command)
          if(execute_command(command,logfile)!=True):
           return
          ansf_time += time.time()-start
          print("Ans-fold time: {0:.4f}".format(ansf_time))
      # end for on row blocks
      total_time = time.time()-start0
      print("Elapsed time: {0:.4f}".format(total_time))      
      if args.r:
        compression_report(args,vc_time,repair_time,iv_time,ansf_time,total_time)
      
      # DISABLED: delete temporary .vc file
      if False and not args.k: # temporarily disabled 
        command = "rm -f {mfile}.vc".format(mfile=basename)
        if(execute_command(command,logfile)!=True):
          return



  print("==== Done")

def getsize_multipart(base,num,ext):
  tot = 0
  for i in range(num):
    name = base + filext_multipart(num,i)+ext
    tot += os.path.getsize(name)
  return tot

def compression_report(args,tconv,trepair,tiv,tans,ttot):
  print("==== Compression Report:")
  print(" >> matrix name:",args.input);
  print(" >> conversion time: {0:.2f}".format(tconv))
  print(" >> repair time: {0:.2f}".format(trepair))
  print(" >> integer vectors time: {0:.2f}".format(tiv))
  print(" >> ansf time: {0:.2f}".format(tans))
  print(" >> total time: {0:.2f}".format(ttot))  
  isize = 8*args.rows*args.cols
  print(" >> matrix dense size:",isize, "bytes")
  #psize = os.path.getsize(args.input)
  #print(" >> csv representation size: {0} bytes  ({1:.2f}%)".format(psize,100*psize/isize))
  valsize = os.path.getsize(args.input + ".val")
  vcsize = getsize_multipart(args.input,args.b,".vc") 
  nonzero = vcsize//4 - args.rows
  print(" >> total number of nonzero: {0} ({1:.2f}%)".format(nonzero,100*nonzero/(args.rows*args.cols)))
  print(" >> number of distinct nonzero: {0}".format(valsize//8))
  psize = valsize+vcsize
  print(" >> CSRV  size: {0} bytes  ({1:.2f}%)".format(psize,100*psize/isize))
  csize = getsize_multipart(args.input,args.b,".vc.C") 
  rsize = getsize_multipart(args.input,args.b,".vc.R") 
  psize = valsize + csize+rsize
  print(" >> RE32  size:", psize, "bytes  ({0:.2f}%)".format(100*psize/isize))
  csizeiv = getsize_multipart(args.input,args.b,".vc.C.iv") 
  rsizeiv = getsize_multipart(args.input,args.b,".vc.R.iv") 
  psize = valsize + csizeiv+rsizeiv
  print(" >> REIV  size:", psize, "bytes  ({0:.2f}%)".format(100*psize/isize))
  ans_csize = getsize_multipart(args.input,args.b,".vc.C.ansf.1")
  # REANS32 no longer considered
  # psize = valsize+ans_csize+rsize 
  # print(" >> REANS32 size:", psize, "bytes  ({0:.2f}%)".format(100*psize/isize))
  psize = valsize+ans_csize+rsizeiv 
  print(" >> REANS size:", psize, "bytes  ({0:.2f}%)".format(100*psize/isize))


def show_command_line(f):
  f.write("\n#### " + datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S"))
  f.write("\n Command line: ") 
  for x in sys.argv:
     f.write(x+" ")
  f.write("\n")   


